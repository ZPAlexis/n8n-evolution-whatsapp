# === EVOLUTION API ===
SERVER_URL=https://api.yourdomain.com
AUTHENTICATION_API_KEY=
LANGUAGE=en
CONFIG_SESSION_PHONE_VERSION=2.3000.1039011911
WEB_VERSION=2.3000.1039011911

# DB - Service name defined in docker-compose
DATABASE_PROVIDER=postgresql
DATABASE_CONNECTION_URI='postgresql://n8n:n8npass@postgres:5432/n8n?schema=evolution_api'
DATABASE_CONNECTION_CLIENT_NAME=evolution_exchange
DATABASE_SAVE_DATA_INSTANCE=true
DATABASE_SAVE_DATA_NEW_MESSAGE=true
DATABASE_SAVE_MESSAGE_UPDATE=true
DATABASE_SAVE_DATA_CONTACTS=true
DATABASE_SAVE_DATA_CHATS=true
DATABASE_SAVE_DATA_LABELS=true
DATABASE_SAVE_DATA_HISTORIC=true

# Cache - Set to false for simplest setup
CACHE_REDIS_ENABLED=true
CACHE_REDIS_URI=redis://redis:6379/6
CACHE_REDIS_PREFIX_KEY=evolution
CACHE_REDIS_SAVE_INSTANCES=true
CACHE_LOCAL_ENABLED=false

# === n8n ===
GENERIC_TIMEZONE=America/Sao_Paulo
TZ=America/Sao_Paulo
N8N_ENCRYPTION_KEY=
N8N_DB_TYPE=postgresdb
WEBHOOK_URL=https://n8n.yourdomain.com

# Proxy
PROXY_HOST=proxy.webshare.io
PROXY_PORT=80
PROXY_PROTOCOL=http
PROXY_USERNAME=your_webshare_user
PROXY_PASSWORD=your_webshare_pass